{
  "name": "linuxdo-moyu",
  "displayName": "Linux.do Moyu",
  "description": "在 VS Code 里浏览 Linux.do（Discourse）论坛的扩展，提供最新帖子、分类、通知与回复能力。",
  "version": "0.1.0",
  "publisher": "lucifercoo",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "linuxdo.refresh",
        "title": "Linux.do: 刷新论坛"
      },
      {
        "command": "linuxdo.configureConnection",
        "title": "Linux.do: 配置连接"
      },
      {
        "command": "linuxdo.loginWithBrowser",
        "title": "Linux.do: 使用 Linux DO Connect 登录"
      },
      {
        "command": "linuxdo.browserLoginAndImportSession",
        "title": "Linux.do: 浏览器登录并接管会话"
      },
      {
        "command": "linuxdo.loginWithCookie",
        "title": "Linux.do: 使用 Linux.do Cookie 登录"
      },
      {
        "command": "linuxdo.clearConnection",
        "title": "Linux.do: 清除连接"
      },
      {
        "command": "linuxdo.__test.setScenario",
        "title": "Linux.do: 设置测试场景"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "linuxdo",
          "title": "Linux.do",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "linuxdo": [
        {
          "type": "webview",
          "id": "linuxdo.mainView",
          "name": "Forum"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "linuxdo.refresh",
          "when": "view == linuxdo.mainView",
          "group": "navigation@1"
        },
        {
          "command": "linuxdo.configureConnection",
          "when": "view == linuxdo.mainView",
          "group": "navigation@2"
        },
        {
          "command": "linuxdo.browserLoginAndImportSession",
          "when": "view == linuxdo.mainView",
          "group": "navigation@3"
        },
        {
          "command": "linuxdo.loginWithBrowser",
          "when": "view == linuxdo.mainView",
          "group": "navigation@4"
        },
        {
          "command": "linuxdo.loginWithCookie",
          "when": "view == linuxdo.mainView",
          "group": "navigation@5"
        },
        {
          "command": "linuxdo.clearConnection",
          "when": "view == linuxdo.mainView",
          "group": "navigation@6"
        }
      ]
    },
    "configuration": {
      "title": "Linux.do Moyu",
      "properties": {
        "linuxdo.baseUrl": {
          "type": "string",
          "default": "https://linux.do",
          "description": "Discourse 站点地址，默认使用 https://linux.do。"
        },
        "linuxdo.requestTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 3000,
          "description": "请求超时时间（毫秒）。"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "compile:ui-test": "tsc -p ./tsconfig.ui-test.json",
    "watch": "tsc -watch -p ./",
    "ui-test": "npm run compile && npm run compile:ui-test && extest setup-and-run --code_version 1.109.5 --storage .extest --code_settings ./test/ui/test-settings.json --mocha_config ./test/ui/.mocharc.js ./out-test/test/ui/smoke.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.5.2",
    "@types/vscode": "1.95.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vscode-extension-tester": "^8.22.1"
  }
}
